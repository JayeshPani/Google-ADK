# Recommended for hackathon deployment: use Vertex AI with billing-enabled GCP.
# For local AI Studio mode, set GOOGLE_GENAI_USE_VERTEXAI=false and fill GOOGLE_API_KEY.
GOOGLE_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8501/auth/google/callback
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
MODEL_ID=gemini-2.5-flash
EVAL_MODEL_ID=gemini-2.5-flash
MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-3.1-flash-lite
EVAL_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-3.1-flash-lite
PHOENIX_API_KEY=your_phoenix_api_key
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=job-rejection-agent
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name
PHOENIX_MCP_ENABLED=true
PHOENIX_MCP_COMMAND=
PHOENIX_MCP_ARGS=
RUN_LIVE_NETWORK_TESTS=false
RUN_LIVE_PROMPT_GATE_TESTS=false
FIRESTORE_PROJECT_ID=
FIRESTORE_COLLECTION=job_packets
FIRESTORE_USER_COLLECTION=users
SESSION_DB_URL=sqlite+aiosqlite:///./.local/adk_sessions.db
LOCAL_STORAGE_PATH=.local/job_packets.json
LOCAL_USER_STORAGE_PATH=.local/users.json
IMPROVEMENT_STATE_PATH=.local/prompt_improvement_state.json
APP_SECRET_KEY=replace-with-a-long-random-secret
PROMPT_VERSION=baseline-v1
AUTO_PROMPT_IMPROVEMENT_ENABLED=true
AUTO_PROMPT_IMPROVEMENT_EVERY_N_DIAGNOSES=5
